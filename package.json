{
  "name": "tpp",
  "displayName": "T++ Language",
  "description": "Provides syntax highlighting, language configuration, and tooling support for the T++ programming language — a human-first, natural English-based programming system.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "tpp",
      "aliases": ["T++", "tpp"],
      "extensions": [".tpp"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "tpp",
      "scopeName": "source.tpp",
      "path": "./syntaxes/tpp.tmLanguage.json"
    }],
    "snippets": [
  {
    "language": "tpp",
    "path": "./tpp.code-snippets"
  }
]
  }
}
